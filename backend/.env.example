# ─── DATABASE ────────────────────────────────────────────────────────────────
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/pharmaagent

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Generate a strong random string for production (min 32 chars)
# Windows: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── GOOGLE GEMINI AI ────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── LANGSMITH OBSERVABILITY ─────────────────────────────────────────────────
# Get your key at: https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=false if you want to skip LangSmith setup
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=pharmaagent-ai

# ─── APP SETTINGS ─────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# ─── PHASE 3 — VOICE, WEBHOOKS, ANALYTICS ────────────────────────────────────

# Server TTS: set true only if you add a cloud TTS provider
USE_SERVER_TTS=false

# Fulfillment webhook URL — uses built-in mock simulator by default
FULFILLMENT_WEBHOOK_URL=http://localhost:8000/webhook/simulate

# Retry settings for webhook delivery (exponential backoff)
WEBHOOK_MAX_RETRIES=3
WEBHOOK_BASE_DELAY=1.0
WEBHOOK_MAX_DELAY=30.0

# Rate limiting (requests per minute, per user)
RATE_LIMIT_PER_MINUTE=60

# Max file size for prescription image uploads (bytes — 10MB default)
MAX_UPLOAD_SIZE_BYTES=10485760

# Directory for uploaded prescription images
UPLOAD_DIR=uploads
