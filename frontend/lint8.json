               <Link href=\"/admin\" className=\"btn-secondary text-sm py-2 px-4\">\r\n                                Admin View\r\n                            </Link>\r\n                        )}\r\n                    </GlassCard>\r\n                </div>\r\n\r\n                {/* Recent Orders */}\r\n                <GlassCard hover={false} padding=\"none\">\r\n                    <div className=\"p-6 border-b border-white/10 flex items-center justify-between\">\r\n                        <h2 className=\"font-bold text-white text-lg\">Recent Orders</h2>\r\n                        <span className=\"text-sm text-slate-400\">{orders.length} total</span>\r\n                    </div>\r\n\r\n                    {loading ? (\r\n                        <div className=\"flex justify-center p-12\">\r\n                            <div className=\"spinner\" />\r\n                        </div>\r\n                    ) : orders.length === 0 ? (\r\n                        <div className=\"text-center p-12 text-slate-400\">\r\n                            <div className=\"text-4xl mb-3\">≡ƒô¡</div>\r\n                            <p>No orders yet. <Link href=\"/chat\" className=\"text-indigo-400 hover:underline\">Place your first order ΓåÆ</Link></p>\r\n                        </div>\r\n                    ) : (\r\n                        <div className=\"overflow-x-auto\">\r\n                            <table className=\"table-glass\">\r\n                                <thead>\r\n                                    <tr>\r\n                                        <th>Order ID</th>\r\n                                        <th>Medicine</th>\r\n                                        <th>Qty</th>\r\n                                        <th>Total</th>\r\n                                        <th>Status</th>\r\n                                        <th>Date</th>\r\n                                    </tr>\r\n                                </thead>\r\n                