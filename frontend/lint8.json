lassName=\"text-indigo-400 font-mono text-xs\">#{med.id}</td>\r\n                                            <td className=\"text-white font-medium\">{med.name}</td>\r\n                                            <td>\r\n                                                <span className={med.stock < 50 ? \"text-amber-400 font-semibold\" : \"text-slate-300\"}>\r\n                                                    {med.stock}\r\n                                                </span>\r\n                                                {med.stock < 50 && <span className=\"text-amber-400 ml-1 text-xs\">ΓÜá∩╕Å Low</span>}\r\n                                            </td>\r\n                                            <td className=\"text-slate-400\">{med.unit}</td>\r\n                                            <td>Γé╣{med.price.toFixed(2)}</td>\r\n                                            <td>\r\n                                                {med.prescription_required\r\n                                                    ? <span className=\"badge-rx\">Rx</span>\r\n                                                    : <span className=\"badge-otc\">OTC</span>}\r\n                                            </td>\r\n                                            <td className=\"text-slate-500 text-xs\">{med.expiry_date ?? \"ΓÇö\"}</td>\r\n                                        </tr>\r\n                                    ))}\r\n                                </tbody>\r\n                            </table>\r\n                        </div>\r\n                    </GlassCard>\r\n                )}\r\n\r\n                {/* Orders Table */}\r\n                {activeTab === \"orders\" && (\r\n                    <GlassCard hover={false} padding=\"none\">\r\n                        <div className=\"p-5 border-b border-white/10\">\r\n                            <h2 className=\"font-bold text-white\">All Orders</h2>\r\n                        </div>\r\n                    